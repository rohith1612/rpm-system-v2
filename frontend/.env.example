# ══════════════════════════════════════════════════════════════════════
# RPM Frontend Environment Variables (Vercel Deployment)
# ══════════════════════════════════════════════════════════════════════

# URL of your deployed Python/FastAPI backend on Render
# Example: https://rpm-system-backend.onrender.com/api
# Default for local development: http://localhost:8000/api
VITE_API_BASE=http://localhost:8000/api

# WebSocket URL of your deployed Python/FastAPI backend on Render
# Example: wss://rpm-system-backend.onrender.com/ws
# Default for local development: ws://localhost:8000/ws
VITE_WS_URL=ws://localhost:8000/ws
