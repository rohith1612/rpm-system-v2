# ══════════════════════════════════════════════════════════════════════
# RPM Backend Environment Variables (Render Deployment)
# ══════════════════════════════════════════════════════════════════════

# ── Cerner FHIR R4 ──────────────────────────────────────────────
# The FHIR R4 base URL for your Cerner sandbox tenant.
CERNER_BASE_URL=https://fhir-ehr-code.cerner.com/r4/<YOUR_TENANT_ID>

# The OAuth2 token endpoint for your Cerner tenant.
CERNER_TOKEN_URL=https://authorization.cerner.com/tenants/<YOUR_TENANT_ID>/protocols/oauth2/profiles/smart-v1/token

# ── SMART on FHIR OAuth2 (Provider App — Public Client) ─────────
# The Client ID of your registered Provider app.
CLIENT_ID=<YOUR_PROVIDER_APP_CLIENT_ID>

# The redirect URI registered with Cerner for the OAuth callback.
# When deploying to Vercel, this must be: https://<YOUR_FRONTEND_DOMAN>.vercel.app/callback
REDIRECT_URI=https://<YOUR_FRONTEND_DOMAIN>.vercel.app/callback

# SMART on FHIR scopes requested during authorization.
SMART_SCOPES=user/Patient.read user/Encounter.read user/Encounter.write user/Condition.read user/Observation.read user/Observation.write online_access openid profile fhirUser launch/patient

# ── SMART on FHIR OAuth2 (System App — Client Credentials) ──────
# Register a second app in Cerner Code Console with type = "System" for background syncs.
SYSTEM_APP_ID=<YOUR_SYSTEM_APP_ID>
SYSTEM_CLIENT_ID=<YOUR_SYSTEM_APP_CLIENT_ID>
SYSTEM_SECRET=<YOUR_SYSTEM_APP_SECRET>
SYSTEM_SCOPES=system/Patient.read system/Observation.read system/Observation.write system/Encounter.read

# ── Database ──────────────────────────────────────────────
# Connection string for NeonDB (serverless Postgres).
DATABASE_URL=postgresql://<NEONDB_USER>:<NEONDB_PASSWORD>@<NEONDB_HOST>/<NEONDB_DATABASE>?sslmode=require

# ── MQTT Broker Configuration ──────────────────────────────
# HiveMQ Cloud broker hostname (without protocol prefix).
MQTT_BROKER=<YOUR_HIVEMQ_CLUSTER_URL>
MQTT_PORT=8883
MQTT_USERNAME=<YOUR_HIVEMQ_USERNAME>
MQTT_PASSWORD=<YOUR_HIVEMQ_PASSWORD>

# ── Application Settings ────────────────────────────────────
# Toggle automatic background syncing of vitals to Cerner (true/false)
ENABLE_CERNER_AUTO_SYNC=false

# App POV Mode: DEV (detailed developer terminal view) or CUS (minimal customer view)
APP_POV=DEV

# Groq API Key for AI-powered health insights
GROQ_API_KEY=<YOUR_GROQ_API_KEY>

# ── OpenTelemetry Configuration ────────────────────────────
# Service name appearing in Grafana dashboards
OTEL_SERVICE_NAME=rpm-backend

# Protocol used to send metrics to your OTel Collector (http/protobuf or http/json)
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Endpoint for your OpenTelemetry Collector
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Telemetry export options (true/false)
OTEL_EXPORT_TRACES_TO_OTLP=false
OTEL_EXPORT_METRICS_TO_OTLP=false
OTEL_EXPORT_LOGS_TO_OTLP=false

# Local telemetry file logging options (true/false)
OTEL_EXPORT_TRACES_TO_FILE=true
OTEL_EXPORT_METRICS_TO_FILE=true
