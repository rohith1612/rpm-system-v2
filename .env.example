# ╔══════════════════════════════════════════════════════════════════════╗
# ║        Remote Patient Monitoring System — Environment Variables      ║
# ║                                                                      ║
# ║  Copy this file to .env and fill in your actual values.              ║
# ║  Run:  cp .env.example .env                                         ║
# ╚══════════════════════════════════════════════════════════════════════╝


# ══════════════════════════════════════════════════════════════════════
# 1. CERNER FHIR R4 — Base URLs
# ══════════════════════════════════════════════════════════════════════
# The FHIR R4 base URL for your Cerner sandbox tenant.
# Format: https://fhir-ehr-code.cerner.com/r4/<TENANT_ID>
# Get this from: Cerner Code Console -> Your App -> FHIR Base URL
CERNER_BASE_URL=https://fhir-ehr-code.cerner.com/r4/<YOUR_TENANT_ID>

# The OAuth2 token endpoint for your Cerner tenant.
# Format: https://authorization.cerner.com/tenants/<TENANT_ID>/protocols/oauth2/profiles/smart-v1/token
CERNER_TOKEN_URL=https://authorization.cerner.com/tenants/<YOUR_TENANT_ID>/protocols/oauth2/profiles/smart-v1/token


# ══════════════════════════════════════════════════════════════════════
# 2. SMART on FHIR OAuth2 — Provider App (Public Client)
# ══════════════════════════════════════════════════════════════════════
# The Client ID assigned when you register a "Provider" app in Cerner Code Console.
# This is for the user-facing OAuth2 Authorization Code flow (provider login).
CLIENT_ID=<YOUR_PROVIDER_APP_CLIENT_ID>

# The redirect URI registered with Cerner for the OAuth callback.
# Must exactly match what you registered in the Cerner Code Console.
# Default for local development:
REDIRECT_URI=http://localhost:5173/callback

# SMART on FHIR scopes requested during authorization.
# These control what FHIR resources the app can read/write on behalf of the logged-in user.
# Scopes used by this app:
#   user/Patient.read       - Read patient demographics
#   user/Encounter.read     - Read encounter records
#   user/Encounter.write    - Write encounter records
#   user/Condition.read     - Read patient conditions
#   user/Observation.read   - Read vital signs & observations
#   user/Observation.write  - Write vital signs from RPM devices
#   online_access           - Maintain session while user is active
#   openid profile fhirUser - OIDC identity (who is logged in)
#   launch/patient          - Receive patient context at launch
SMART_SCOPES=user/Patient.read user/Encounter.read user/Encounter.write user/Condition.read user/Observation.read user/Observation.write online_access openid profile fhirUser launch/patient


# ══════════════════════════════════════════════════════════════════════
# 3. SMART on FHIR OAuth2 — System App (Client Credentials / Backend)
# ══════════════════════════════════════════════════════════════════════
# These are for the backend "System" app which runs without user login.
# Used for automated syncing of vitals to Cerner in the background.
# Register a second app in Cerner Code Console with type = "System".

# The Application ID of your System app (shown on the app details page).
SYSTEM_APP_ID=<YOUR_SYSTEM_APP_ID>

# The System app's Client ID (different from the Provider app above).
SYSTEM_CLIENT_ID=<YOUR_SYSTEM_APP_CLIENT_ID>

# The System app's client secret.
# WARNING: NEVER commit this value to version control!
SYSTEM_SECRET=<YOUR_SYSTEM_APP_SECRET>

# Scopes for the system-level app.
# These are "system/" scoped (not "user/") because there is no user context.
SYSTEM_SCOPES=system/Patient.read system/Observation.read system/Observation.write system/Encounter.read


# ══════════════════════════════════════════════════════════════════════
# 4. DATABASE — NeonDB (Serverless PostgreSQL)
# ══════════════════════════════════════════════════════════════════════
# Connection string for NeonDB (serverless Postgres).
# Format: postgresql://<USER>:<PASSWORD>@<HOST>/<DATABASE>?sslmode=require
# Get this from: NeonDB Dashboard -> Connection Details -> Connection String
# WARNING: NEVER commit this value to version control!
DATABASE_URL=postgresql://<NEONDB_USER>:<NEONDB_PASSWORD>@<NEONDB_HOST>/<NEONDB_DATABASE>?sslmode=require


# ══════════════════════════════════════════════════════════════════════
# 5. MQTT BROKER — HiveMQ Cloud
# ══════════════════════════════════════════════════════════════════════
# HiveMQ Cloud broker hostname (without protocol prefix).
# Get this from: HiveMQ Cloud Console -> Cluster -> Overview -> URL
# Example: abc123def456.s1.eu.hivemq.cloud
MQTT_BROKER=<YOUR_HIVEMQ_CLUSTER_URL>

# MQTT port — HiveMQ Cloud uses TLS on port 8883.
MQTT_PORT=8883

# MQTT credentials — Create these in the HiveMQ Cloud Console under
# "Access Management" -> "Credentials" tab.
# WARNING: NEVER commit these values to version control!
MQTT_USERNAME=<YOUR_HIVEMQ_USERNAME>
MQTT_PASSWORD=<YOUR_HIVEMQ_PASSWORD>


# ══════════════════════════════════════════════════════════════════════
# 6. APPLICATION SETTINGS
# ══════════════════════════════════════════════════════════════════════

# Toggle automatic syncing of RPM vitals to Cerner FHIR server.
# Set to "true" to enable, "false" to disable.
# When disabled, vitals are stored locally in NeonDB only.
ENABLE_CERNER_AUTO_SYNC=false

# App Point-of-View mode:
#   DEV - Detailed developer terminal view (shows logs, MQTT messages, API calls)
#   CUS - Minimal customer-facing loading animation view
APP_POV=DEV

# Groq API Key for AI-powered health insights.
# Get this from: https://console.groq.com -> API Keys
# WARNING: NEVER commit this value to version control!
GROQ_API_KEY=<YOUR_GROQ_API_KEY>
